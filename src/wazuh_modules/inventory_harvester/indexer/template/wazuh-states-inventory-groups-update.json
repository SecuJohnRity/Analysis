{
  "index_patterns": [
    "wazuh-states-inventory-groups*"
  ],
  "priority": 2,
  "template": {
    "settings": {},
    "mappings": {
      "date_detection": false,
      "dynamic": "strict",
      "properties": {
        "agent_id": {"type": "keyword"}, "scan_time": {"type": "date"}, "@timestamp": {"type": "alias", "path": "scan_time"}, "type": {"type": "keyword"},
        "host": {"properties": {"ip": {"type": "ip"}, "hostname": {"type": "keyword"}}},
        "group": {
          "properties": {
            "description": {"type": "match_only_text"},
            "id": {"type": "unsigned_long"},
            "id_signed": {"type": "long"},
            "is_hidden": {"type": "boolean"},
            "name": {"ignore_above": 1024, "type": "keyword"},
            "users": {"ignore_above": 1024, "type": "keyword"},
            "uuid": {"ignore_above": 1024, "type": "keyword"}
          }
        }
      }
    }
  }
}
